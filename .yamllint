---
extends: default

rules:
  braces:
    max-spaces-inside: 1
  line-length:
    max: 120
    level: warning
  octal-values:
    forbid-implicit-octal: true
    forbid-explicit-octal: true
  truthy:
    allowed-values: ["true", "false", "on"]
  comments:
    min-spaces-from-content: 1
  comments-indentation: disable

ignore: |
  collections/
