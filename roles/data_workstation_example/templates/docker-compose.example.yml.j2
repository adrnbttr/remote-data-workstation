# Example data stack for the workstation (generated by Ansible).
# Start it with: docker compose -f docker-compose.example.yml up -d
services:
  db:
    image: {{ dwx_postgres_image }}
    restart: unless-stopped
    environment:
      POSTGRES_USER: ${POSTGRES_USER:-dev}
      POSTGRES_PASSWORD: ${POSTGRES_PASSWORD:-dev}
      POSTGRES_DB: ${POSTGRES_DB:-app}
    ports:
      - "{{ dwx_postgres_port }}:5432"
    volumes:
      - db-data:/var/lib/postgresql/data

  adminer:
    image: adminer:4
    restart: unless-stopped
    ports:
      - "8080:8080"

volumes:
  db-data:
